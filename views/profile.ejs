<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= member.name %> - Profile</title>
    <script defer src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <style>
        * { box-sizing: border-box; }

        body { 
            font-family: 'Georgia', serif; 
            background: radial-gradient(circle, #f4ece1 0%, #d9e2d5 100%);
            background-attachment: fixed;
            color: #3e2723; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            min-height: 100vh;
            margin: 0;
            padding: 0; /* Remove padding for true full-screen on mobile */
        }

        .profile-container { 
            background-color: #fffaf4;
            background-image: url('/familytree/profiletree.webp'); 
            background-repeat: no-repeat;
            background-position: center bottom;
            background-size: cover;
            padding: 12px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.2); 
            max-width: 100%; /* Stretch to phone width */
            width: 100vw; 
            height: 100vh; /* Stretch to phone height */
            text-align: center;
            border: 8px solid #1a0f0d; 
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .photo-frame-container {
            position: relative;
            width: 100%;
            line-height: 0;
        }

        .photo-border-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 20;
            pointer-events: none;
            object-fit: fill;
        }

        .main-photo { 
            width: 100%;
            height: auto;
            aspect-ratio: 16 / 9;
            object-fit: cover;
            padding: 8.5% 11.5% 8% 10.5%; 
            position: relative;
            z-index: 5;
            opacity: 0; 
            transition: opacity 0.5s ease-in-out;
        }

        .parchment-banner {
            background: #f1e4d1;
            border: 2px solid #bda07b;
            padding: 4px 10px;
            margin: 2px auto;
            width: 92%;
            font-style: italic;
            font-size: 0.9em;
            color: #5d4037;
        }

        .fact-box {
            background-image: url('/familytree/lower.webp');
            background-size: 100% 100%;
            background-repeat: no-repeat;
            color: #f4ece1;
            padding: 25px 35px; 
            text-align: left;
            width: 100%; 
            flex-grow: 1; /* Allow the box to grow to fill mobile height */
            min-height: 180px;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.9);
        }

        .fact-box h3 {
            margin: 0 0 8px 0;
            text-align: center;
            border-bottom: 1px solid rgba(215, 204, 200, 0.4);
            font-size: 1.1em;
        }

        .fact-item { margin-bottom: 6px; display: flex; align-items: center; gap: 8px; font-size: 0.85em; }

        /* DEVICE BREAKPOINTS */

        @media (min-width: 600px) {
            body { padding: 20px; justify-content: center; }
            .profile-container { 
                border-width: 12px; 
                padding: 20px; 
                gap: 12px; 
                max-width: 550px; 
                width: 100%; 
                height: auto; 
                min-height: 80vh;
                border-radius: 15px;
            }
            .fact-box { padding: 40px 50px; min-height: 250px; flex-grow: 0; }
            .parchment-banner { font-size: 1.1em; padding: 8px; }
        }

        @media (min-width: 1025px) {
            .profile-container { border-width: 14px; padding: 30px; max-width: 600px; gap: 15px; }
            .fact-box { padding: 60px 80px; min-height: 300px; }
            .main-photo { padding: 8.2% 11.5% 8% 10.2%; }
            h1 { font-size: 2.2em; }
        }

        .controls-container { margin-top: 5px; }
        #photoSlider { width: 85%; accent-color: #81c784; cursor: pointer; }
        .back-btn { text-decoration: none; color: #5d4037; font-weight: bold; font-size: 0.8em; margin-bottom: 5px; }

        h1 { font-size: 1.5em; margin: 5px 0 0 0; color: #4e342e; }
        .details { font-size: 0.8em; margin: 0; color: #8d6e63; }
    </style>
</head>
<body>
    <div class="profile-container">
        <div class="photo-frame-container">
            <img src="/familytree/border.webp" class="photo-border-overlay" alt="frame-border">
            <% 
               const filteredAlbum = member.album.filter(img => img !== member.mainImg);
               const initialPhoto = filteredAlbum.length > 0 ? filteredAlbum[0] : member.mainImg;
            %>
            <img src="/familytree/<%= initialPhoto %>" 
                 class="main-photo" 
                 id="morphingFrame" 
                 crossorigin="anonymous"
                 data-album='<%- JSON.stringify(filteredAlbum) %>'>
            
            <h1><%= member.name %></h1>
            <p class="details">Born: <%= member.birthday %> | <%= member.location %></p>
        </div>

        <div class="parchment-banner">"<%= member.knownFor %>"</div>

        <div class="fact-box">
            <h3>Memories</h3>
            <div class="fact-item">🌿 Key family milestones</div>
            <div class="fact-item">🌿 First words, steps, and hobbies</div>
            <div class="fact-item">🌿 Favorite family vacations</div>
        </div>

        <div class="controls-container" id="controls" style="display: none;">
            <input type="range" id="photoSlider" min="0" value="0">
            <div><button id="playPauseBtn" style="background:none; border:1px solid #5d4037; border-radius:10px; cursor:pointer; color:#5d4037; padding: 2px 10px; font-size:0.8em;">Pause</button></div>
        </div>

        <a href="/familytree" class="back-btn">← Back</a>
    </div>

    <script>
        const photoList = JSON.parse(document.getElementById('morphingFrame').dataset.album);
        const frame = document.getElementById('morphingFrame');
        const slider = document.getElementById('photoSlider');
        const playPauseBtn = document.getElementById('playPauseBtn');
        const controls = document.getElementById('controls');

        let currentIndex = 0;
        let isPlaying = false;
        let streamInterval;
        let modelsLoaded = false;

        window.onload = () => {
            if (photoList.length > 0) {
                controls.style.display = 'block';
                slider.max = photoList.length - 1;
                loadModels();
            } else {
                frame.style.opacity = '1';
            }
        };

        async function loadModels() {
            const MODEL_URL = 'https://justadudewhohacks.github.io/face-api.js/models';
            try {
                await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
                modelsLoaded = true;
                await updateDisplay(0, true);
                if (photoList.length > 1) {
                    isPlaying = true;
                    streamInterval = setInterval(nextPhoto, 3000);
                }
            } catch (e) {
                frame.style.opacity = '1';
            }
        }

        async function updateDisplay(index, isInitial = false) {
            if (photoList.length === 0) return;
            currentIndex = index;
            if (!isInitial) frame.style.opacity = '0';

            const tempImg = new Image();
            tempImg.crossOrigin = "anonymous"; 
            tempImg.src = "/familytree/" + photoList[currentIndex];

            tempImg.onload = async function() {
                frame.src = tempImg.src;
                if (modelsLoaded && typeof faceapi !== 'undefined') {
                    const detections = await faceapi.detectAllFaces(frame, new faceapi.TinyFaceDetectorOptions());
                    if (detections.length > 0) {
                        const box = detections[0].box;
                        const centerX = ((box.x + box.width / 2) / frame.naturalWidth) * 100;
                        const centerY = ((box.y + box.height / 2.5) / frame.naturalHeight) * 100;
                        frame.style.objectPosition = `${centerX}% ${centerY}%`;
                    }
                }
                slider.value = currentIndex;
                frame.style.opacity = '1';
            };
        }

        function nextPhoto() {
            if (photoList.length <= 1) return;
            updateDisplay((currentIndex + 1) % photoList.length);
        }

        function togglePlay() {
            if (isPlaying) clearInterval(streamInterval);
            else streamInterval = setInterval(nextPhoto, 3000);
            isPlaying = !isPlaying;
            playPauseBtn.innerText = isPlaying ? "Pause" : "Play";
        }

        slider.oninput = function() {
            if (isPlaying) togglePlay(); 
            updateDisplay(parseInt(this.value));
        };

        playPauseBtn.onclick = togglePlay;
    </script>   
</body>
</html>
