<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= member.name %> - Profile</title>
    <script defer src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <style>
        * { box-sizing: border-box; }

        body { 
            font-family: 'Georgia', serif; 
            background: radial-gradient(circle, #f4ece1 0%, #d9e2d5 100%);
            background-attachment: fixed;
            color: #3e2723; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            min-height: 100vh;
            margin: 0;
            padding: 0; 
        }

        .profile-container { 
            background-color: #fffaf4;
            background-image: url('/familytree/profiletree.webp'); 
            background-repeat: no-repeat;
            background-position: center bottom;
            background-size: cover;
            padding: 10px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.2); 
            max-width: 100%; 
            width: 100vw; 
            height: 100vh; 
            text-align: center;
            border: 8px solid #1a0f0d; 
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 0; /* Remove gap to allow flex to handle spacing */
        }

        /* TOP SECTION: Photo and Title */
        .top-section {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            width: 100%;
        }

        .photo-frame-container {
            position: relative;
            width: 100%;
            max-width: 450px;
            line-height: 0;
        }

        .photo-border-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 20;
            pointer-events: none;
            object-fit: fill;
        }

        .main-photo { 
            width: 100%;
            height: auto;
            aspect-ratio: 16 / 9;
            object-fit: cover;
            padding: 8.5% 11.5% 8% 10.5%; 
            position: relative;
            z-index: 5;
            opacity: 0; 
            transition: opacity 0.5s ease-in-out;
            background: transparent;
        }

        /* MIDDLE SECTION: Parchment Banner */
        .parchment-banner {
            background: #f1e4d1;
            border: 1px solid #bda07b;
            padding: 6px 15px;
            margin: 10px auto;
            width: 90%;
            font-style: italic;
            font-size: 0.9em;
            color: #5d4037;
            z-index: 30;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        /* BOTTOM SECTION: Stats and Controls */
        .bottom-section {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            width: 100%;
            padding-bottom: 5px;
        }

        .fact-box {
            background-image: url('/familytree/lower.webp');
            background-size: 100% 100%;
            background-repeat: no-repeat;
            color: #f4ece1;
            padding: 25px 45px; 
            text-align: left;
            width: 100%; 
            flex: 1; /* Makes the box fill the remaining space in the bottom section */
            text-shadow: 1px 1px 3px rgba(0,0,0,0.9);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .fact-box h3 {
            margin: 0 0 10px 0;
            text-align: center;
            border-bottom: 1px solid rgba(215, 204, 200, 0.4);
            font-size: 1.2em;
            font-variant: small-caps;
        }

        .fact-item { margin-bottom: 8px; display: flex; align-items: center; gap: 10px; font-size: 0.9em; }
        .stat-label { font-weight: bold; color: #d7ccc8; min-width: 80px; display: inline-block; }

        @media (min-width: 600px) {
            body { padding: 20px; justify-content: center; }
            .profile-container { 
                border-width: 12px; padding: 25px; 
                max-width: 550px; width: 100%; height: auto; min-height: 85vh; border-radius: 15px;
            }
            .fact-box { padding: 45px 65px; min-height: 250px; }
            .parchment-banner { font-size: 1.1em; padding: 10px; }
        }

        @media (min-width: 1025px) {
            .profile-container { border-width: 14px; padding: 35px; max-width: 600px; }
            .fact-box { padding: 60px 80px; min-height: 300px; }
            .main-photo { padding: 8.2% 11.5% 8% 10.2%; }
            h1 { font-size: 2.2em; }
        }

        .controls-container { padding: 5px 0; }
        #photoSlider { width: 85%; accent-color: #81c784; cursor: pointer; }
        .back-btn { text-decoration: none; color: #5d4037; font-weight: bold; font-size: 0.85em; }

        h1 { font-size: 1.5em; margin: 8px 0 0 0; color: #4e342e; line-height: 1.2; }
    </style>
</head>
<body>
    <div class="profile-container">
        <div class="top-section">
            <div class="photo-frame-container">
                <img src="/familytree/border.webp" class="photo-border-overlay" alt="frame-border">
                <% 
                   const main = (member.mainImg || "").toLowerCase().trim();
                   const filteredAlbum = member.album.filter(img => img.toLowerCase().trim() !== main);
                   const initialPhoto = filteredAlbum.length > 0 ? filteredAlbum[0] : '';
                %>
                <img src="/familytree/<%= initialPhoto %>" 
                     class="main-photo" 
                     id="morphingFrame" 
                     crossorigin="anonymous"
                     data-album='<%- JSON.stringify(filteredAlbum) %>'>
            </div>
            <h1><%= member.name %></h1>
        </div>

        <div class="parchment-banner">"<%= member.knownFor %>"</div>

        <div class="bottom-section">
            <div class="fact-box">
                <h3>Vital Records</h3>
                <div class="fact-item"><span class="stat-label">Born:</span> <%= member.birthday %></div>
                <div class="fact-item"><span class="stat-label">Location:</span> <%= member.location %></div>
                <hr style="border: 0; border-top: 1px solid rgba(215, 204, 200, 0.2); margin: 10px 0;">
                <div class="fact-item">🌿 Key family milestones</div>
                <div class="fact-item">🌿 Favorite family vacations</div>
            </div>

            <div class="controls-container" id="controls" style="display: none;">
                <input type="range" id="photoSlider" min="0" value="0">
                <div style="margin-top: 4px;">
                    <button id="playPauseBtn" style="background:rgba(255,250,244,0.3); border:1px solid #5d4037; border-radius:10px; cursor:pointer; color:#5d4037; padding: 2px 15px; font-size:0.85em;">Pause</button>
                </div>
            </div>

            <a href="/familytree" class="back-btn">← Back to Tree</a>
        </div>
    </div>

    <script>
        const photoList = JSON.parse(document.getElementById('morphingFrame').dataset.album);
        const frame = document.getElementById('morphingFrame');
        const slider = document.getElementById('photoSlider');
        const playPauseBtn = document.getElementById('playPauseBtn');
        const controls = document.getElementById('controls');

        let currentIndex = 0;
        let isPlaying = false;
        let streamInterval;
        let modelsLoaded = false;

        window.onload = () => {
            if (photoList.length > 0) {
                controls.style.display = 'block';
                slider.max = photoList.length - 1;
                loadModels();
            } else {
                frame.style.opacity = '1';
            }
        };

        async function loadModels() {
            const MODEL_URL = 'https://justadudewhohacks.github.io/face-api.js/models';
            try {
                await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
                modelsLoaded = true;
                await updateDisplay(0, true);
                if (photoList.length > 1) {
                    isPlaying = true;
                    streamInterval = setInterval(nextPhoto, 3000);
                }
            } catch (e) {
                frame.style.opacity = '1';
            }
        }

        async function updateDisplay(index, isInitial = false) {
            if (!photoList || photoList.length === 0) return;
            currentIndex = index;
            if (!isInitial) frame.style.opacity = '0';

            const tempImg = new Image();
            tempImg.crossOrigin = "anonymous"; 
            tempImg.src = "/familytree/" + photoList[currentIndex];

            tempImg.onload = async function() {
                frame.src = tempImg.src;
                if (modelsLoaded && typeof faceapi !== 'undefined') {
                    const detections = await faceapi.detectAllFaces(frame, new faceapi.TinyFaceDetectorOptions());
                    if (detections.length > 0) {
                        const box = detections[0].box;
                        const centerX = ((box.x + box.width / 2) / frame.naturalWidth) * 100;
                        const centerY = ((box.y + box.height / 2.5) / frame.naturalHeight) * 100;
                        frame.style.objectPosition = `${centerX}% ${centerY}%`;
                    }
                }
                slider.value = currentIndex;
                frame.style.opacity = '1';
            };
        }

        function nextPhoto() {
            if (photoList.length <= 1) return;
            updateDisplay((currentIndex + 1) % photoList.length);
        }

        function togglePlay() {
            if (isPlaying) clearInterval(streamInterval);
            else streamInterval = setInterval(nextPhoto, 3000);
            isPlaying = !isPlaying;
            playPauseBtn.innerText = isPlaying ? "Pause" : "Play";
        }

        slider.oninput = function() {
            if (isPlaying) togglePlay(); 
            updateDisplay(parseInt(this.value));
        };

        playPauseBtn.onclick = togglePlay;
    </script>   
</body>
</html>
